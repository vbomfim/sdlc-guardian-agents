#!/usr/bin/env bash
# Security Guardian — Pre-Push Hook
# Warns if a security scan has NOT been run since the last commit.
#
# Install: ./tools/install-hooks.sh
# How it works:
#   - After each scan, a timestamp is saved to .security-scan-timestamp
#   - This hook compares that timestamp to the last commit time
#   - If the scan is older than the commit (or never ran), it warns
#
# On feature branches: ⚠ WARNING (push proceeds, but you're notified)
# On main/master:      🚫 BLOCKED (push is rejected — run the scan first)

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

TIMESTAMP_FILE=".security-scan-timestamp"
MAIN_BRANCHES="main master"

# Get the current branch
current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

# Check if pushing to a protected branch
is_main_branch() {
  for branch in $MAIN_BRANCHES; do
    if [ "$current_branch" = "$branch" ]; then
      return 0
    fi
  done
  return 1
}

# Get last commit timestamp (epoch)
last_commit_time=$(git log -1 --format=%ct 2>/dev/null || echo "0")

# Get last scan timestamp (epoch)
if [ -f "$TIMESTAMP_FILE" ]; then
  last_scan_time=$(cat "$TIMESTAMP_FILE" 2>/dev/null || echo "0")
else
  last_scan_time="0"
fi

# Compare
if [ "$last_scan_time" -ge "$last_commit_time" ] 2>/dev/null; then
  echo -e "${GREEN}🛡️  Security Guardian: Scan is up to date${NC}"
  exit 0
fi

# Scan is stale or never ran
if is_main_branch; then
  echo ""
  echo -e "${RED}${BOLD}🚫 Security Guardian: Push to ${current_branch} BLOCKED${NC}"
  echo ""
  echo -e "${RED}  A security scan has not been run since your last commit.${NC}"
  echo -e "${RED}  This is required before pushing to ${current_branch}.${NC}"
  echo ""
  echo -e "  Run one of these commands first:"
  echo -e "    ${CYAN}./tools/setup.sh --scan${NC}          # Full scan"
  echo -e "    ${CYAN}semgrep scan --config=auto .${NC}     # Quick SAST scan"
  echo ""
  echo -e "  Or use ${CYAN}/agent${NC} in Copilot CLI to invoke Security Guardian."
  echo ""
  exit 1
else
  echo ""
  echo -e "${YELLOW}${BOLD}⚠️  Security Guardian: Scan not run since last commit${NC}"
  echo ""
  echo -e "${YELLOW}  Your last security scan is older than your latest commit.${NC}"
  echo -e "${YELLOW}  This push will proceed, but the CI/CD security gate${NC}"
  echo -e "${YELLOW}  will enforce checks before merging to main.${NC}"
  echo ""
  echo -e "  Run a scan before your PR:"
  echo -e "    ${CYAN}./tools/setup.sh --scan${NC}          # Full scan"
  echo -e "    ${CYAN}semgrep scan --config=auto .${NC}     # Quick SAST scan"
  echo ""
  echo -e "  💡 Use ${CYAN}/agent${NC} in Copilot CLI → Security Guardian for a full review."
  echo ""
  exit 0  # Allow push on feature branches (warning only)
fi
